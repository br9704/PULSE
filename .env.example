# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Mapbox (public token, safe in client)
VITE_MAPBOX_TOKEN=

# Google Places API — SERVER SIDE ONLY, used in Supabase Edge Functions
# NEVER put this in VITE_ prefixed vars
# Set this in Supabase Edge Function secrets dashboard
# GOOGLE_PLACES_API_KEY=

# Web Push VAPID — SERVER SIDE ONLY, used in Edge Functions
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=
